FROM node:24.13.0-alpine
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.27.0 --activate

# Manifests do workspace para pnpm install reconhecer o monorepo
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY app-backend/package.json ./app-backend/
COPY app-web/package.json ./app-web/

RUN pnpm install --frozen-lockfile

# Config files necessários para o NestJS compilar
COPY app-backend/tsconfig.json ./app-backend/
COPY app-backend/tsconfig.build.json ./app-backend/
COPY app-backend/nest-cli.json ./app-backend/

# Prisma schema e config para gerar o client durante o build
COPY app-backend/prisma ./app-backend/prisma
COPY app-backend/prisma.config.ts ./app-backend/prisma.config.ts

RUN pnpm --filter goapprove-backend prisma:generate

WORKDIR /app/app-backend

COPY app-backend/entrypoint.dev.sh /entrypoint.dev.sh
RUN chmod +x /entrypoint.dev.sh

ENTRYPOINT ["/entrypoint.dev.sh"]
