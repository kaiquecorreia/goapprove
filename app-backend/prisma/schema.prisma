generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMINISTRATOR
  APPROVER
  VIEWER
  RULES_MANAGER
  EXTERNAL_INTEGRATION
}

enum Environment {
  DEVELOPMENT
  HOMOLOGATION
  PRODUCTION
}

enum Provider {
  INFOR
}

enum AuthType {
  oauth2
}

model Company {
  companyId                  String        @id @default(uuid()) @map("company_id") @db.Uuid
  externalIntegrationCode    String        @unique @map("external_integration_code") @db.VarChar(50)
  name                       String        @map("name") @db.VarChar(150)
  cnpj                       String?       @map("cnpj") @db.VarChar(14)
  status                     Boolean       @default(true)
  externalIntegrationUrlBase String?       @map("external_integration_url_base") @db.Text
  environment                Environment   @map("environment")
  notes                      String?       @map("notes") @db.Text
  createdAt                  DateTime      @default(now()) @map("created_at")
  updatedAt                  DateTime      @updatedAt @map("updated_at")

  users                      CompanyUser[]
  integrations               CompanyIntegration[]

  @@map("companies")
}

model User {
  userId                  String         @id @default(uuid()) @map("user_id") @db.Uuid
  name                    String         @map("name") @db.VarChar(150)
  email                   String         @unique @map("email") @db.VarChar(150)
  externalIntegrationUser String         @unique @map("external_integration_user") @db.VarChar(50)
  role                    UserRole       @map("role")
  active                  Boolean        @default(true) @map("active")
  approvalLimit           Decimal?       @map("approval_limit") @db.Decimal(15, 2)
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  companies               CompanyUser[]
  substitutes             UserSubstitute[] @relation("UserAsOriginal")
  substitutedBy           UserSubstitute[] @relation("UserAsSubstitute")

  @@map("users")
}

model CompanyUser {
  companyId String   @map("company_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  company   Company  @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([companyId, userId])
  @@map("companies_users")
}

model UserSubstitute {
  userId       String   @map("user_id") @db.Uuid
  substituteId String   @map("substitute_id") @db.Uuid
  priority     Int      @default(1) @map("priority")
  createdAt    DateTime @default(now()) @map("created_at")
  
  user         User     @relation("UserAsOriginal", fields: [userId], references: [userId], onDelete: Cascade)
  substitute   User     @relation("UserAsSubstitute", fields: [substituteId], references: [userId], onDelete: Cascade)

  @@id([userId, substituteId])
  @@map("users_substitutes")
}

model CompanyIntegration {
  integrationId String   @id @default(uuid()) @map("integration_id") @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  provider      Provider @map("provider")
  authType      AuthType @default(oauth2) @map("auth_type")
  baseUrl       String   @map("base_url") @db.Text
  clientId      String?  @map("client_id") @db.VarChar(255)
  clientSecret  String?  @map("client_secret") @db.Text
  customData    Json?    @map("custom_data")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company       Company  @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@unique([companyId, provider])
  @@map("company_integrations")
}