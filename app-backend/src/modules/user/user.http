@baseUrl = http://localhost:3012
@userId = 00000000-0000-4000-a000-000000000001
@companyId = 00000000-0000-4000-a000-000000000099

### Create a new user
# companyIds is required for any role other than ADMINISTRATOR.
POST {{baseUrl}}/user
Content-Type: application/json

{
  "name": "Clauber Correia",
  "email": "clauber.correia@goapprove.com.br",
  "externalIntegrationUser": "clauber.correia@goapprove.com.br",
  "role": "OWNER",
  "active": true,
  "approvalLimit": null,
  "companyIds": null,
  "substituteIds": []
}

### List all users
GET {{baseUrl}}/user

### Get user by ID
GET {{baseUrl}}/user/{{userId}}

### Update a user
PATCH {{baseUrl}}/user/{{userId}}
Content-Type: application/json

{
  "name": "John Doe Updated",
  "email": "john.updated@example.com",
  "active": false,
  "approvalLimit": 10000
}
